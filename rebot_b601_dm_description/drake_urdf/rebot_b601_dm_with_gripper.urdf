        </mesh>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

  <joint name="joint1" type="revolute">
    <origin rpy="0 0 0" xyz="-8.416E-05 0 0.08465"/>
    <parent link="base_link"/>
    <child link="link1"/>
    <axis xyz="0 0 1"/>
    <limit effort="27" lower="-2.8" upper="2.8" velocity="50"/>
    <dynamics damping="1.0"/>
  </joint>

