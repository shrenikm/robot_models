      <origin rpy="0 0 0" xyz="0.00937154605945142 -0.0183514409006279 -0.00213050813223617"/>
      <mass value="0.0423278952416158"/>
      <inertia ixx="9.68819007445228E-06" ixy="-1.14547785891207E-06" ixz="1.82410432419993E-08" iyy="9.7195653452821E-06" iyz="1.20737618180169E-07" izz="1.13638462227589E-05"/>
