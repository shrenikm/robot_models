<?xml version="1.0"?>

<!--
Drake URDF of the Seeed Studio reBot Arm B601 DM (6-DOF Damiao-motor arm with the stock actuated
parallel gripper). Kinematics, joint limits and inertials come from the manufacturer's URDF in
https://github.com/Seeed-Projects/reBotArmController_ROS2 (reBot_B601_DM_with_gripper.urdf);
visual meshes are decimated OBJ conversions of the original STLs and collision geometry is a set
of tight convex primitives fitted to each link. See the package README for details.
-->

<robot xmlns:drake="http://drake.mit.edu" name="rebot_b601_dm_with_gripper">

  <material name="Black">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>
  <material name="Silver">
    <color rgba="0.82 0.82 0.83 1.0"/>
  </material>
  <material name="NeonGreen">
    <color rgba="0.62 0.82 0.2 1.0"/>
  </material>

  <link name="base_link">
    <inertial>
      <origin rpy="0 0 0" xyz="-7.849E-06 -1.1531E-06 0.029841"/>
      <mass value="0.83660000"/>
      <inertia ixx="0.00133040" ixy="0.00000001" ixz="0.00000000" iyy="0.00213119" iyz="0.00000000" izz="0.00275877"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://rebot_b601_dm_description/meshes/links/visual/base_link.obj"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="Black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://rebot_b601_dm_description/meshes/links/collision/base_link/base_link_box1.obj">
          <drake:declare_convex/>
        </mesh>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
    <collision>
      <geometry>
        <mesh filename="package://rebot_b601_dm_description/meshes/links/collision/base_link/base_link_box2.obj">
          <drake:declare_convex/>
        </mesh>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

  <link name="link1">
    <inertial>
      <origin rpy="0 0 0" xyz="0.000113614552951627 -0.000616319527051323 0.0236476372671394"/>
      <mass value="0.16130000"/>
      <inertia ixx="0.00025207" ixy="0.00000000" ixz="-0.00002832" iyy="0.00015464" iyz="0.00000000" izz="0.00023416"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://rebot_b601_dm_description/meshes/links/visual/link1.obj"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="Silver"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://rebot_b601_dm_description/meshes/links/collision/link1/link1_box1.obj">
          <drake:declare_convex/>
        </mesh>
