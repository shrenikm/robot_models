    </collision>
    <collision>
      <geometry>
        <mesh filename="package://rebot_b601_dm_description/meshes/links/collision/link1/link1_box2.obj">
          <drake:declare_convex/>
        </mesh>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
    <collision>
      <geometry>
        <mesh filename="package://rebot_b601_dm_description/meshes/links/collision/link1/link1_box3.obj">
