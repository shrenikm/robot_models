      <inertia ixx="9.68819002375832E-06" ixy="1.14547786360874E-06" ixz="-1.82410118281856E-08" iyy="9.7195652747221E-06" iyz="1.20737613592695E-07" izz="1.13638461944347E-05"/>
    </inertial>
