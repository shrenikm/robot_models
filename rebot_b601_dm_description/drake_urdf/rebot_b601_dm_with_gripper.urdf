  <joint name="gripper_joint1" type="prismatic">
    <origin rpy="0 0 -1.5708" xyz="-0.042091 2.7531E-05 -1.3031E-05"/>
    <parent link="gripper_link"/>
    <child link="gripper_left"/>
    <axis xyz="1 0 0"/>
    <limit effort="100" lower="0" upper="0.0715" velocity="15"/>
  </joint>

