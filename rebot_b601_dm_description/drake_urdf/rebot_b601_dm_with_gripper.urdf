  <joint name="gripper_joint2" type="prismatic">
    <origin rpy="0 0 1.5708" xyz="-0.042091 -2.7531E-05 1.3031E-05"/>
    <parent link="gripper_link"/>
    <child link="gripper_right"/>
    <axis xyz="1 0 0"/>
    <limit effort="100" lower="0" upper="0.0715" velocity="15"/>
  </joint>

  <!--
  TCP reference frame for FK / IK. The gripper fingertips meet exactly on the link6 z axis at
  z = 0.15971 (the gripper_link frame origin) when the gripper is closed, so the tip frame sits
  there with the same orientation as link6: z is the tool approach axis, y is the finger travel
  direction.
  -->
  <link name="link_eef_tip"/>

  <joint name="joint_eef_tip" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0.15971"/>
    <parent link="link6"/>
    <child link="link_eef_tip"/>
  </joint>

  <!--
  The two fingers touch at the closed state (q = 0), so mutual finger contact is filtered out;
  objects being grasped still collide with each finger individually.
  -->
  <drake:collision_filter_group name="gripper_fingers">
    <drake:member link="gripper_left"/>
    <drake:member link="gripper_right"/>
    <drake:ignored_collision_filter_group name="gripper_fingers"/>
  </drake:collision_filter_group>

  <!--
  The link6 flange is permanently nested inside the link4 wrist bracket (their tight convex
  envelopes overlap at every joint configuration), so this pair is filtered like an adjacent
  pair. Any real flange-bracket contact would first show up as the adjacent link4-link5 pair
  hitting its joint limit.
  -->
  <drake:collision_filter_group name="wrist_bracket">
    <drake:member link="link4"/>
    <drake:ignored_collision_filter_group name="wrist_flange"/>
  </drake:collision_filter_group>
  <drake:collision_filter_group name="wrist_flange">
    <drake:member link="link6"/>
  </drake:collision_filter_group>

  <!-- Actuators -->
  <transmission name="tran1">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint1">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor1">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
      <drake:gear_ratio value="40.0"/>
    </actuator>
  </transmission>

  <transmission name="tran2">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint2">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor2">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
