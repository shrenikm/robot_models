  <!--
  TCP reference frame for FK / IK. The gripper fingertips meet exactly on the link6 z axis at
  z = 0.15971 (the gripper_link frame origin) when the gripper is closed, so the tip frame sits
  there with the same orientation as link6: z is the tool approach axis, y is the finger travel
  direction.
  -->
  <link name="link_eef_tip"/>

  <joint name="joint_eef_tip" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0.15971"/>
    <parent link="link6"/>
    <child link="link_eef_tip"/>
  </joint>

  <!-- Actuators -->
  <transmission name="tran1">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint1">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor1">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="tran2">
