      <origin rpy="0 0 0" xyz="-2.70523135620574E-06 -7.70134319499296E-06 0.028980835090929"/>
      <mass value="0.79874480798149"/>
      <inertia ixx="0.00167922927706365" ixy="1.88775164237686E-09" ixz="-1.97136369561029E-08" iyy="0.00100413042930826" iyz="2.1823444305057E-07" izz="0.00243992061460991"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://rebot_b601_dm_description/meshes/links/visual/base_link.obj"/>
